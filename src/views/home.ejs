<div class="space-y-6">

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    
    <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-blue-600">
      <p class="text-sm text-gray-500 font-medium">Total Mahasiswa</p>
      <p class="text-4xl font-bold text-blue-600 mt-2"><%= totalMhs %></p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-green-600">
      <p class="text-sm text-gray-500 font-medium">Total Dosen</p>
      <p class="text-4xl font-bold text-green-600 mt-2">35</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow border-l-4 border-purple-600">
      <p class="text-sm text-gray-500 font-medium">Total Matkul</p>
      <p class="text-4xl font-bold text-purple-600 mt-2">50</p>
    </div>

  </div>

  <div class="bg-white p-6 rounded-2xl shadow">
    <h2 class="text-lg font-bold mb-4 text-gray-800">Data Mahasiswa</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-100 text-gray-600 uppercase text-xs">
          <tr>
            <th class="py-3 px-4 text-center">No</th>
            <th class="py-3 px-4">Nama</th>
            <th class="py-3 px-4">NIM</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% if (mahasiswa.length > 0) { %>
            <% mahasiswa.forEach((mhs, index) => { %>
            <tr class="hover:bg-gray-50 transition">
              <td class="py-3 px-4 text-center font-medium"><%= index + 1 %></td>
              <td class="py-3 px-4"><%= mhs.nama %></td>
              <td class="py-3 px-4"><%= mhs.nim %></td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="3" class="py-10 text-center text-gray-400 italic">Belum ada data mahasiswa.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</div>